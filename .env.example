# Web QA Stress Agent — Environment Variables

# Target URL (can also be passed via --url)
TARGET_URL=https://staging.example.com

# Output directory (can also be passed via --out)
OUT_DIR=./data/runs/demo

# Environment label
ENV=staging

# Read-only mode (default: true)
READ_ONLY=true

# Denylist / Allowlist (comma-separated action types or patterns)
# DENYLIST=delete,remove,destroy
# ALLOWLIST=

# Limits
MAX_PAGES=50
UI_CONCURRENCY=5
RERUN_FAILURES=2

# Jira integration (not used in v1, but validated)
JIRA_ENABLED=false
# JIRA_BASE_URL=https://yourcompany.atlassian.net
# JIRA_PROJECT=QA
# JIRA_EMAIL=you@company.com
# JIRA_API_TOKEN=your-token-here

# LLM integration (not used in v1, but validated)
LLM_PROVIDER=none
# LLM_MODEL=gpt-4
# OPENAI_API_KEY=sk-...
# ANTHROPIC_API_KEY=sk-ant-...
